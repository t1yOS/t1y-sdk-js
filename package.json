{
  "name": "t1y-sdk-js",
  "version": "5.0.4",
  "description": "t1yOS Serverless Platform JavaScript/TypeScript SDK — cloud database, metadata, and cloud functions client",
  "author": "华易云联（杭州）网络科技有限责任公司",
  "license": "MIT",
  "keywords": [
    "t1y",
    "t1yos",
    "serverless",
    "baas",
    "sdk",
    "database",
    "cloud-functions",
    "mongodb"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/t1yOS/t1y-os-js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/umd/t1y.min.js",
  "jsdelivr": "./dist/umd/t1y.min.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "build:all": "pnpm run build && pnpm run build:umd",
    "build:umd": "esbuild src/index.browser.ts --bundle --minify --format=iife --global-name=T1Y --outfile=dist/umd/t1y.min.js --target=es2017 --external:@system.fetch --external:@system.storage",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "echo 'Lint not configured yet'",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "prepublishOnly": "pnpm run build:all"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "esbuild": "^0.20.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "sideEffects": false,
  "packageManager": "pnpm@11.5.2"
}
